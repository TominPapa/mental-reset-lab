# ─────────────────────────────────────────────────────────────
# Mental Reset Lab — environment variables
# Copy this file to `.env.local` and fill in real values.
# .env.local is gitignored and must never be committed.
# ─────────────────────────────────────────────────────────────

# Supabase (https://app.supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — SERVER ONLY, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (https://console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...
# Model used for article/script generation
ANTHROPIC_MODEL=claude-sonnet-4-6

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Mental Reset Lab

# YouTube channel (for the /watch page CTA — manual, no API)
NEXT_PUBLIC_YOUTUBE_CHANNEL_URL=https://www.youtube.com/@your-channel

# Cron secret — protects POST /api/revalidate (set the same value in Vercel Cron header)
CRON_SECRET=generate-a-long-random-string

# Google Analytics (optional, leave empty to disable)
NEXT_PUBLIC_GA_ID=
